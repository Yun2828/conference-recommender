# Ignore everything by default
*

# Keep this file
!.gitignore

# Keep README files
!README.md
!README.docx

# Keep Streamlit app folder
!Streamlit Application/
!Streamlit Application/**

# Keep Other Python Files folder
!Other Python Files/
!Other Python Files/**

# Ignore virtual environments anywhere
.venv/
venv/
**/.venv/
**/venv/

# macOS
.DS_Store
**/.DS_Store

# Python
__pycache__/
**/__pycache__/
*.pyc
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# Node
node_modules/
.next/
dist/
build/

# Environment variables / secrets
.env
.env.local
.env.example
*.env
secrets.toml
.streamlit/secrets.toml
**/.streamlit/secrets.toml

# Logs
*.log

# Videos / large demo files
*.mp4
*.mov
*.avi
*.mkv

# Large/generated ML files
*.pkl
*.joblib
*.pt
*.h5
*.onnx

# Common binary documents, but allow README.docx above
*.pdf
*.exe
*.xlsx
*.xls
*.xlsm
*.csv
*.ppt
*.pptx
*.doc
*.docx
!README.docx
